<?xml version="1.0" encoding="utf-8"?>
<!--코드로 챗을 감쌀 수 있는 화면을 만들 것-->
<!--   1. solid로 버블 안을 채워줌-->
<!--   2. stroke로 버블 라인을 감쌈 width : 선 굵기-->
<!--   3. corners로 모서리를 깎음-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid
        android:color="@color/colorWhite"/>
    <stroke
        android:width="0.8dp"
        android:color="@color/colorDark"/>

    <corners
        android:radius="13dp"/>
</shape>