<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <!--또래상담 관련 아이템 : 상담사 프로필사진, 상담사이름, 프로필 메세지, 상담상태 : 상담중 or 상담가능, 즐겨찾기-->

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_friends_profile"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:padding="10dp"
        android:background="@drawable/chat_bubble"
        android:scaleType="centerCrop"
        android:src="@drawable/profileimg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/tv_friend_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="상담사"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:textSize="25sp"
        android:textStyle="bold"
        android:textColor="@color/colorDark"
        app:layout_constraintStart_toEndOf="@+id/iv_friends_profile"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_friend_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="10dp"
        android:text="상담가능"
        android:textStyle="bold"
        android:paddingEnd="10dp"
        android:textSize="20sp"
        android:textColor="@color/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_friend_msg"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:text="프로필 메세지"
        android:paddingStart="10dp"
        android:gravity="center_vertical"
        android:paddingBottom="5dp"
        android:textSize="22sp"
        android:maxLines="2"
        app:layout_constraintTop_toBottomOf="@id/tv_friend_name"
        app:layout_constraintStart_toEndOf="@+id/iv_friends_profile"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>