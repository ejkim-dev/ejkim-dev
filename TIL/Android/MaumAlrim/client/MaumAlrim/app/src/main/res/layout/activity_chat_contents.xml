<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ChatContentsActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimaryDark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:weightSum="1.0">

<!--            <ImageView-->
<!--                android:id="@+id/img_back"-->
<!--                android:onClick="onBackPage"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_weight="0.2"-->
<!--                android:src="@drawable/ic_navigate_before_black_24dp"-->
<!--                android:layout_gravity="center"-->
<!--                android:clickable="true"/>-->

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_weight="1"
                android:text="상담채팅방"
                android:textStyle="bold"
                android:textSize="22sp"/>

<!--            <ImageView-->
<!--                android:id="@+id/img_close"-->
<!--                android:onClick="onChangPage"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_weight="0.2"-->
<!--                android:src="@drawable/ic_close_black_24dp"-->
<!--                android:layout_gravity="center"-->
<!--                android:clickable="true"/>-->
        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat_part"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:background="@color/colorPrimaryDark"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/rv_chat_part"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:weightSum="1.0">

<!--            <ImageView-->
<!--                android:id="@+id/img_back"-->
<!--                android:onClick="onBackPage"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_weight="0.2"-->
<!--                android:src="@drawable/ic_navigate_before_black_24dp"-->
<!--                android:layout_gravity="center"-->
<!--                android:clickable="true"/>-->

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.8"
                android:gravity="center_vertical"
                android:text="상담요약 및 방향제시"
                android:textStyle="bold"
                android:textSize="22sp"/>

            <Button
                android:id="@+id/bt_submit"
                android:onClick="onSubmit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.2"
                android:text="제출"
                android:textSize="20sp"
                android:src="@drawable/ic_close_black_24dp"
                android:layout_gravity="end"
                android:clickable="true"/>
        </LinearLayout>


    </androidx.appcompat.widget.Toolbar>


    <ScrollView
        android:id="@+id/edt_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        app:layout_constraintTop_toBottomOf="@+id/toolbar2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <EditText
            android:id="@+id/et_summary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="오늘 상담한 내용 요약과 방향제시 작성"
            android:textSize="20dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"/>
    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>